<!DOCTYPE html>
<html lang="uk">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Математичні ігри{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧮</text></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="header">
            <a href="{{ path('app_home') }}" class="header__logo">🧮 Матемагія</a>
            {% if app.user %}
                <div class="header__user">
                    <span class="header__greeting">Привіт, {{ app.user.username }}!</span>
                    <a href="{{ path('app_stats') }}" class="header__logout">📊 Статистика</a>
                    <a href="{{ path('app_logout') }}" class="header__logout">Вийти</a>
                </div>
            {% endif %}
        </header>
        <main class="main">
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
